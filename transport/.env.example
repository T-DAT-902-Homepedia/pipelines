# Configuration du pipeline gold transport (silver parquet -> PostGIS).
# Copier en `.env` et adapter, puis charger avant de lancer un script :
#   set -a; source .env; set +a
#   uv run python scripts/load_transport_commune.py

# --- Source silver (MinIO local / S3) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=homepedia
MINIO_ROOT_PASSWORD=pass-minio
HOMEPEDIA_S3_BUCKET=homepedia
HOMEPEDIA_SILVER_PREFIX=silver

# --- Cible PostGIS (mêmes conventions que le pipeline DVF) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=homepedia
POSTGRES_USER=homepedia
POSTGRES_PASSWORD=pass-postgres
