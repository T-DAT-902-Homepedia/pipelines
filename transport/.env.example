# Configuration du pipeline gold transport (silver parquet duckpipe -> PostGIS).
# Copier en `.env` et adapter, puis charger avant de lancer le script :
#   set -a; source .env; set +a
#   uv run python scripts/load_transport_commune.py

# --- Source silver (sortie locale de duckpipe) ---
# Défaut : ../duckpipe/data/silver (run `python -m duckpipe run transport --env local`)
# HOMEPEDIA_SILVER_DIR=../duckpipe/data/silver

# --- Cible PostGIS (mêmes conventions que le pipeline DVF) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=homepedia
POSTGRES_USER=homepedia
POSTGRES_PASSWORD=pass-postgres
