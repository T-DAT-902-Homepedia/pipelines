# Configuration de l'ingestion bronze -> S3.
# Copier en `.env` et adapter, puis charger les variables avant de lancer un script :
#   set -a; source .env; set +a
#   uv run python scripts/ingest_transport.py

# --- Cible S3 (commun MinIO local et AWS réel) ---
HOMEPEDIA_S3_BUCKET=homepedia
HOMEPEDIA_S3_PREFIX=bronze

# --- MinIO local (via `just up data`) ---
# Laisser AWS_ENDPOINT_URL vide / commenté pour viser AWS réel.
AWS_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
